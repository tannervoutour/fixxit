# Tool Configuration - Controls which tools are available to the AI
# Set to true to enable a tool, false to disable it
# Changes take effect without system restart

# Documentation Tools (NEW - enabled by default)
TOOL_MACHINE_DOCS=true
TOOL_MANUAL_SECTIONS=true
TOOL_TROUBLESHOOTING=true
TOOL_SECTION_CONTENT=true
TOOL_PROCEDURES=true

# System Tools
TOOL_SYSTEM_OVERVIEW=true
TOOL_DATABASE_QUERY=true

# OLD MAINTENANCE TOOLS (disabled - no longer exist)
# These are kept for reference but have no effect
TOOL_SEARCH_EQUIPMENT=false
TOOL_MAINTENANCE_TICKETS=false
TOOL_SERVICE_HISTORY=false
TOOL_PARTS_INVENTORY=false
TOOL_TECHNICIAN_INFO=false

# Notes:
# - Documentation tools provide access to machine manuals and procedures
# - Troubleshooting tools search across all manual content
# - Database query tool allows complex custom queries
# - System overview shows documentation processing status